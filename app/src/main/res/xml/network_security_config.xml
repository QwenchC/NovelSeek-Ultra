<?xml version="1.0" encoding="utf-8"?>
<!--
  Cleartext (http://) is required to reach a self-hosted ComfyUI server, which runs on a
  user-supplied LAN address (e.g. http://192.168.1.100:8188) with no TLS. The host is dynamic
  (entered in Settings) so it can't be pinned to a fixed domain; cleartext is permitted globally.
  All other traffic (Pollinations, AI providers) uses HTTPS regardless.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true" />
</network-security-config>
