<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- App runtime theme -->
    <style name="Theme.NovelSeekUltra" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>
    <!-- SplashScreen theme: shown by the OS during cold start (covers the blank startup window) -->
    <style name="Theme.NovelSeekUltra.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/white</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.NovelSeekUltra</item>
    </style>
</resources>